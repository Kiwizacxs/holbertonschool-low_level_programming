#include "main.h"
#include <string.h>
#include <stdio.h>

/**
 * _strcpy  - check the code
 * @dest: men
 * @src: woman
 * Return: Always 0.
 */

char *_strcpy(char *dest, char *src)
{
	int b = 0;
	int r = 0;

	while (*dest != '\0')
	{
		b++;
		dest++;
	}
	while (*src != '\0')
	{
		b++;
		dest[b] = src[r];
		r++;
		src++;
	}
	return (dest);
}

